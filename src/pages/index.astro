---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import CTAWhatsApp from '../components/CTAWhatsApp.astro';
import { products, getFeaturedProducts } from '../data/products';

const featuredProducts = getFeaturedProducts();
---

<BaseLayout title="Bem-vindo">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Background Gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary-50 to-white" />
    
    <div class="container-custom section-padding relative">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8 md:gap-12 items-center">
        <!-- Content -->
        <div class="space-y-8 animate-slideInLeft">
          <div class="space-y-4">
            <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-primary-900 animate-slideInLeft animation-delay-100">
              Bem-vindo à <span class="gradient-text">Cereon</span>
            </h1>
            <p class="text-base sm:text-lg md:text-xl text-gray-600 leading-relaxed animate-slideInLeft animation-delay-200">
              Moda premium com qualidade garantida. Roupas, calçados e acessórios selecionados para você se sentir confiante.
            </p>
          </div>
          
          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 animate-slideInLeft animation-delay-300">
            <a href="/catalogo" class="button-primary hover:scale-105">
              Explorar Catálogo
            </a>
            <CTAWhatsApp variant="secondary" text="Tirar Dúvidas" />
          </div>

          <!-- Benefits -->
          <div class="grid grid-cols-2 gap-4 sm:gap-6 pt-6 sm:pt-8 border-t border-gray-200 animate-slideInLeft animation-delay-400">
            <div class="transition-all duration-300 hover:-translate-y-1">
              <p class="text-xs sm:text-sm font-semibold text-accent uppercase mb-1">+500</p>
              <p class="text-xs sm:text-sm text-gray-600">Clientes Satisfeitos</p>
            </div>
            <div class="transition-all duration-300 hover:-translate-y-1">
              <p class="text-xs sm:text-sm font-semibold text-accent uppercase mb-1">+9</p>
              <p class="text-xs sm:text-sm text-gray-600">Peças Em Catálogo</p>
            </div>
          </div>
        </div>

        <!-- Visual -->
        <div class="hidden lg:flex items-center justify-center animate-slideInRight">
          <div class="relative w-full max-w-md aspect-square group">
            <!-- Background glow effect -->
            <div class="absolute inset-0 bg-gradient-to-br from-accent/20 to-accent/5 rounded-2xl animate-glow blur-xl group-hover:blur-2xl transition-all duration-500" />
            
            <!-- Main image container -->
            <div class="relative overflow-hidden rounded-2xl border border-gray-300 group-hover:border-accent/50 transition-all duration-500 shadow-lg group-hover:shadow-xl bg-white p-4">
              <!-- Shine overlay -->
              <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent transform -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-in-out pointer-events-none z-20" />
              
              <img 
                src="/cereon-xl.webp"
                alt="Produtos Cereon"
                class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-700 ease-out"
              />
              
              <!-- Dark overlay on hover -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Products Section -->
  <section class="section-padding animate-fadeIn">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16 animate-slideInUp">
        <p class="text-sm font-semibold text-accent uppercase tracking-widest mb-4">Destaques</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-primary-900 mb-4">
          Coleção em Destaque
        </h2>
        <p class="text-sm sm:text-base md:text-lg text-gray-600 leading-relaxed">
          Descubra nossas peças mais procuradas com qualidade e estilo garantidos
        </p>
      </div>

      <!-- Products Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredProducts.map((product, index) => (
          <div class={`stagger-${Math.min(index + 1, 3)} animate-slideInUp`}>
            <ProductCard product={product} />
          </div>
        ))}
      </div>

      <!-- View All Link -->
      <div class="text-center mt-12 sm:mt-16 animate-slideInUp animation-delay-300">
        <a href="/catalogo" class="button-primary hover:scale-105">
          Ver Catálogo Completo
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Section -->
  <section class="section-padding bg-gray-50/50 animate-fadeIn">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16 animate-slideInUp">
        <h2 class="text-4xl sm:text-5xl font-bold text-primary-900 mb-4">
          Por que Cereon?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
        <!-- Qualidade -->
        <div class={`text-center space-y-4 stagger-1 animate-slideInUp card-animate`}>
          <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 md:w-16 md:h-16 bg-accent/10 rounded-full icon-glow hover:bg-accent/20 transition-colors duration-300">
            <svg class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 text-accent transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm3.6-14.4a.6.6 0 00-.84.84L13.32 10l1.44 1.44a.6.6 0 11-.84.84L12.48 10.84l-1.44 1.44a.6.6 0 01-.84-.84L11.64 10l-1.44-1.44a.6.6 0 11.84-.84l1.44 1.44 1.44-1.44a.6.6 0 01.84 0z" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-primary-900">Moda Premium</h3>
          <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
            Apenas peças selecionadas e de qualidade comprovada com excelente caimento
          </p>
        </div>

        <!-- Suporte -->
        <div class={`text-center space-y-4 stagger-2 animate-slideInUp card-animate`}>
          <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 md:w-16 md:h-16 bg-accent/10 rounded-full icon-glow hover:bg-accent/20 transition-colors duration-300">
            <svg class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 text-accent transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-primary-900">Suporte Dedicado</h3>
          <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
            Tim responsável para tirar dúvidas via WhatsApp e Instagram
          </p>
        </div>

        <!-- Confiança -->
        <div class={`text-center space-y-4 stagger-3 animate-slideInUp card-animate`}>
          <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 md:w-16 md:h-16 bg-accent/10 rounded-full icon-glow hover:bg-accent/20 transition-colors duration-300">
            <svg class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 text-accent transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-primary-900">100% Seguro</h3>
          <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
            Transações seguras e garantia de satisfação com todos os produtos
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final Section -->
  <section class="section-padding animate-fadeIn">
    <div class="container-custom">
      <div class="bg-gradient-to-r from-primary-900 to-primary-800 rounded-2xl p-12 sm:p-16 text-center space-y-6 hover:shadow-2xl transition-shadow duration-300 animate-scaleIn">
        <h2 class="text-4xl sm:text-5xl font-bold text-white">
          Pronto para renovar seu guarda-roupa?
        </h2>
        <p class="text-xl text-white/90 max-w-2xl mx-auto leading-relaxed">
          Explore nossa coleção completa e descubra peças que combinam com seu estilo
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/catalogo" class="inline-flex items-center justify-center px-8 py-3 bg-white text-primary-900 font-medium rounded-lg hover:bg-accent hover:text-white transition-all duration-300 hover:scale-105 active:scale-95">
            Ver Catálogo
          </a>
          <CTAWhatsApp variant="ghost" text="Consultar Agora" message="Olá! Gostaria de uma proposta personalizada Cereon." />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global() {
    .animation-delay-100 {
      animation-delay: 0.1s;
    }
    
    .animation-delay-200 {
      animation-delay: 0.2s;
    }
    
    .animation-delay-300 {
      animation-delay: 0.3s;
    }
    
    .animation-delay-400 {
      animation-delay: 0.4s;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    section {
      animation: fadeIn 0.8s ease-in-out;
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
