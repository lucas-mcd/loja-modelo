---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import CTAWhatsApp from '../../components/CTAWhatsApp.astro';
import { products, getProductBySlug } from '../../data/products';

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

interface Props {
  product: any;
}

const { product } = Astro.props;

if (!product) {
  return Astro.redirect('/catalogo');
}

// Get relatedProducts (other 3 products)
const relatedProducts = products
  .filter(p => p.id !== product.id)
  .slice(0, 3);
---

<BaseLayout title={product.name}>
  <!-- Breadcrumb -->
  <section class="container-custom py-6 sm:py-8">
    <div class="flex items-center gap-2 text-sm text-gray-600">
      <a href="/" class="hover:text-accent transition-colors">Início</a>
      <span>/</span>
      <a href="/catalogo" class="hover:text-accent transition-colors">Catálogo</a>
      <span>/</span>
      <span class="text-accent font-medium">{product.name}</span>
    </div>
  </section>

  <!-- Product Details -->
  <section class="container-custom section-padding">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Product Image -->
      <div class="flex items-center justify-center animate-fadeIn">
        <div class="relative w-full max-w-md aspect-square group">
          <!-- Background glow -->
          <div class="absolute inset-0 bg-gradient-to-br from-accent/25 to-accent/5 rounded-3xl animate-glow blur-2xl group-hover:blur-3xl transition-all duration-500" />
          
          <!-- Image container with premium styling -->
          <div class="relative overflow-hidden rounded-3xl border-2 border-accent/20 group-hover:border-accent/60 transition-all duration-500 shadow-2xl group-hover:shadow-[0_25px_70px_rgba(212,165,116,0.5)] group-hover:scale-105 bg-gray-100">
            <!-- Shine effect overlay -->
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/40 to-transparent transform -translate-x-full group-hover:translate-x-full transition-transform duration-800 ease-in-out pointer-events-none z-20" />
            
            <img 
              src={product.image}
              alt={product.imageAlt}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
            />
            
            <!-- Dark gradient overlay on hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/15 via-transparent to-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
          </div>
        </div>
      </div>

      <!-- Product Info -->
      <div class="space-y-8">
        <!-- Category -->
        <div>
          <p class="text-sm font-semibold text-accent uppercase tracking-widest">
            {product.category}
          </p>
        </div>

        <!-- Title -->
        <div>
          <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-primary-900">
            {product.name}
          </h1>
        </div>

        <!-- Price -->
        <div class="border-t border-b border-gray-200 py-6">
          <div class="space-y-4">
            <p class="text-sm text-gray-600">Preco varia conforme tamanho e quantidade</p>
            <p class="text-lg sm:text-2xl font-semibold text-accent">
              Consulte via WhatsApp ou Instagram
            </p>
          </div>
        </div>

        <!-- Description -->
        <div>
          <h3 class="text-lg sm:text-xl font-semibold text-primary-900 mb-4">Descrição</h3>
          <p class="text-base sm:text-lg text-gray-600 leading-relaxed">
            {product.description}
          </p>
        </div>

        <!-- Benefits -->
        <div class="space-y-4">
          <h3 class="text-lg sm:text-xl font-semibold text-primary-900">Por que escolher esta peça?</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 sm:w-6 sm:h-6 text-accent flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
              </svg>
              <span class="text-gray-700">Qualidade e durabilidade garantidas</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 sm:w-6 sm:h-6 text-accent flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
              </svg>
              <span class="text-sm sm:text-base text-gray-700">Conforto e estilo em uma peça</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 sm:w-6 sm:h-6 text-accent flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
              </svg>
              <span class="text-sm sm:text-base text-gray-700">Atendimento e suporte dedicado</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 sm:w-6 sm:h-6 text-accent flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
              </svg>
              <span class="text-sm sm:text-base text-gray-700">Satisfação 100% garantida</span>
            </li>
          </ul>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <CTAWhatsApp 
            size="lg" 
            text="Comprar Agora"
            message={`Olá! Gostaria de comprar: ${product.name}`}
          />
          <a 
            href="/catalogo" 
            class="button-secondary justify-center text-lg"
          >
            Ver Mais Produtos
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  <section class="section-padding bg-gray-50/50">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16">
        <h2 class="text-4xl font-bold text-primary-900 mb-4">
          Produtos Relacionados
        </h2>
        <p class="text-lg text-gray-600 leading-relaxed">
          Confira outros produtos que podem interessar você
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {relatedProducts.map((relProduct) => (
          <ProductCard product={relProduct} />
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-padding">
    <div class="container-custom">
      <div class="bg-gradient-to-r from-primary-900 to-primary-800 rounded-2xl p-12 sm:p-16 text-center space-y-6">
        <h2 class="text-4xl sm:text-5xl font-bold text-white">
          Gostou dessa peça?
        </h2>
        <p class="text-xl text-white/90 max-w-2xl mx-auto leading-relaxed">
          Compre agora através do WhatsApp e receba sua encomenda rapidamente
        </p>
        <div class="flex justify-center">
          <CTAWhatsApp 
            variant="ghost" 
            text="Comprar"
            message={`Olá! Quero comprar: ${product.name}`}
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @media (prefers-reduced-motion: no-preference) {
    section {
      animation: slideUp 0.6s ease-out;
    }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
