---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAWhatsApp from '../components/CTAWhatsApp.astro';
---

<BaseLayout title="Sobre">
  <!-- Mission Section -->
  <section class="section-padding bg-gray-50/50 animate-fadeIn">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8 md:gap-12 items-center">
        <div class="animate-slideInLeft">
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-primary-900 mb-6">
            Nossa Missão
          </h2>
          <p class="text-base sm:text-lg text-gray-600 leading-relaxed mb-6 transition-colors duration-300 hover:text-primary-700">
            Oferecer moda de qualidade, acessível e com estilo para todos. Acreditamos que roupa boa faz a diferença no dia a dia.
          </p>
          <p class="text-lg text-gray-600 leading-relaxed transition-colors duration-300 hover:text-primary-700">
            Cada peça é selecionada com cuidado, garantindo conforto, durabilidade e design que combina com você.
          </p>
        </div>
        <div class="relative aspect-square rounded-xl overflow-hidden animate-slideInRight group bg-white border border-gray-300 group-hover:border-accent/50 transition-colors duration-500 p-3">
          <img 
            src="/cereon-xl.webp"
            alt="Cereon - Missão e Visão"
            class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="section-padding animate-fadeIn">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-8 sm:mb-12 md:mb-16 animate-slideInUp">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-primary-900 mb-4">
          Nossos Valores
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
        <!-- Qualidade -->
        <div class={`space-y-4 text-center stagger-1 animate-slideInUp card-animate`}>
          <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 md:w-16 md:h-16 bg-accent/10 rounded-full icon-glow hover:bg-accent/20 transition-colors duration-300">
            <svg class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 text-accent transition-transform duration-300 group-hover:rotate-12" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-primary-900">Qualidade</h3>
          <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
            Compromisso com produtos e serviços de excelência em todos os detalhes
          </p>
        </div>

        <!-- Profissionalismo -->
        <div class={`space-y-4 text-center stagger-2 animate-slideInUp card-animate`}>
          <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 md:w-16 md:h-16 bg-accent/10 rounded-full icon-glow hover:bg-accent/20 transition-colors duration-300">
            <svg class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 text-accent transition-transform duration-300 group-hover:rotate-12" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-primary-900">Profissionalismo</h3>
          <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
            Atendimento e suporte dedicado com excelência em comunicação
          </p>
        </div>

        <!-- Inovação -->
        <div class={`space-y-4 text-center stagger-3 animate-slideInUp card-animate`}>
          <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 md:w-16 md:h-16 bg-accent/10 rounded-full icon-glow hover:bg-accent/20 transition-colors duration-300">
            <svg class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 text-accent transition-transform duration-300 group-hover:rotate-12" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-primary-900">Inovação</h3>
          <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
            Design moderno e funcional que acompanha as tendências do mercado
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="section-padding bg-gray-50/50 animate-fadeIn">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-8 sm:mb-12 md:mb-16 animate-slideInUp">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-primary-900 mb-4">
          Por que escolher Cereon?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
        <!-- Entrega Rápida -->
        <div class={`space-y-4 stagger-1 animate-slideInUp card-animate`}>
          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-10 w-10 sm:h-12 sm:w-12 items-center justify-center rounded-lg bg-accent/10 icon-glow hover:bg-accent/20 transition-colors duration-300">
                <svg class="h-5 w-5 sm:h-6 sm:w-6 text-accent transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
            </div>
            <div>
              <h3 class="text-base sm:text-lg font-semibold text-primary-900">Entrega Rápida</h3>
              <p class="text-sm text-gray-600 mt-2">Envio para todo o Brasil com prazo garantido</p>
            </div>
          </div>
        </div>

        <!-- Suporte Completo -->
        <div class={`space-y-4 stagger-2 animate-slideInUp card-animate`}>
          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-10 w-10 sm:h-12 sm:w-12 items-center justify-center rounded-lg bg-accent/10 icon-glow hover:bg-accent/20 transition-colors duration-300">
                <svg class="h-5 w-5 sm:h-6 sm:w-6 text-accent transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
            <div>
              <h3 class="text-base sm:text-lg font-semibold text-primary-900">Suporte Completo</h3>
              <p class="text-sm text-gray-600 mt-2">Tim dedicado para dúvidas e sugestões</p>
            </div>
          </div>
        </div>

        <!-- Garantia de Qualidade -->
        <div class={`space-y-4 stagger-3 animate-slideInUp card-animate`}>
          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-10 w-10 sm:h-12 sm:w-12 items-center justify-center rounded-lg bg-accent/10 icon-glow hover:bg-accent/20 transition-colors duration-300">
                <svg class="h-5 w-5 sm:h-6 sm:w-6 text-accent transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
            <div>
              <h3 class="text-base sm:text-lg font-semibold text-primary-900">Garantia de Qualidade</h3>
              <p class="text-sm text-gray-600 mt-2">Peças selecionadas com rigor e atenção</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding animate-fadeIn">
    <div class="container-custom">
      <div class="bg-gradient-to-r from-primary-900 to-primary-800 rounded-2xl p-6 sm:p-8 md:p-12 lg:p-16 text-center space-y-6 hover:shadow-2xl transition-shadow duration-300 animate-scaleIn">
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-white">
          Pronto para começar?
        </h2>
        <p class="text-xl text-white/90 max-w-2xl mx-auto leading-relaxed">
          Explore nossa coleção e encontre o estilo perfeito para você
        </p>
        <div class="flex justify-center">
          <a href="/catalogo" class="inline-flex items-center justify-center px-8 py-3 bg-accent hover:bg-accent/90 text-primary-900 font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:scale-105 active:scale-95">
            Ver Catálogo
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
