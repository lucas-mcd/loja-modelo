---
import type { Product } from '../data/products';
import ProductCard from './ProductCard.astro';

interface Props {
  products: Product[];
}

const { products } = Astro.props;

// Get unique categories
const categories = Array.from(new Set(products.map(p => p.category))).sort();
---

<div class="category-filter">
  <!-- Filter Buttons -->
  <div class="flex flex-wrap gap-2 sm:gap-3 justify-center mb-8 sm:mb-12">
    <button 
      class="filter-btn active px-4 py-1.5 sm:px-6 sm:py-2 bg-accent text-white rounded-full font-medium text-sm sm:text-base transition-all duration-300 hover:bg-opacity-90 hover:scale-110 active:scale-95"
      data-filter="all"
    >
      Tudo
    </button>
    {categories.map((category) => (
      <button 
        class="filter-btn px-4 py-1.5 sm:px-6 sm:py-2 border-2 border-gray-300 text-gray-700 rounded-full font-medium text-sm sm:text-base transition-all duration-300 hover:border-accent hover:text-accent hover:scale-105 active:scale-95"
        data-filter={category}
      >
        {category}
      </button>
    ))}
  </div>

  <!-- Products Grid -->
  <div class="products-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {products.map((product, index) => {
      const staggerClass = Math.min(index + 1, 9);
      return (
        <div class={`product-item stagger-${staggerClass}`}>
          <ProductCard product={product} />
        </div>
      );
    })}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const productCards = document.querySelectorAll('.products-grid .product-item');
    const productsGrid = document.querySelector('.products-grid');

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');

        // Update active button
        filterButtons.forEach(btn => {
          btn.classList.remove('active', 'bg-accent', 'text-white');
          btn.classList.add('border-gray-300', 'text-gray-700');
        });
        
        button.classList.add('active', 'bg-accent', 'text-white');
        button.classList.remove('border-gray-300', 'text-gray-700');

        // Filter and animate products
        const visibleCards = [];
        productCards.forEach((item) => {
          const card = item.querySelector('article');
          const category = card.getAttribute('data-category');
          
          if (filter === 'all' || category === filter) {
            item.style.display = '';
            item.classList.remove('stagger-1', 'stagger-2', 'stagger-3', 'stagger-4', 'stagger-5', 'stagger-6');
            item.classList.add(`stagger-${Math.min(visibleCards.length + 1, 6)}`);
            visibleCards.push(item);
            
            // Restart animation
            card.style.animation = 'none';
            void card.offsetWidth;
            card.style.animation = '';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });

    // Set initial active state
    const allButton = document.querySelector('[data-filter="all"]');
    if (allButton) {
      allButton.classList.add('bg-accent', 'text-white');
      allButton.classList.remove('border-gray-300', 'text-gray-700');
    }
  });
</script>

<style>
  .filter-btn {
    cursor: pointer;
  }

  .filter-btn.active {
    @apply bg-accent text-white border-accent;
  }

  .product-item {
    animation: slideInUp 0.6s ease-out forwards;
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

