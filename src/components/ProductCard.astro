---
import type { Product } from '../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const { name, price, description, image, imageAlt, id } = product;
---

<article 
  class="group bg-white rounded-2xl overflow-hidden border-2 border-gray-100 hover:border-accent shadow-md hover:shadow-2xl transition-all duration-500 ease-out animate-slideInUp hover:scale-105"
  data-category={product.category}
>
  <!-- Imagem do Produto -->
  <div class="relative overflow-hidden bg-white aspect-square border border-gray-200 group-hover:border-accent/30 transition-colors duration-500">
    <!-- Overlay de brilho animado -->
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/25 to-transparent transform -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-in-out pointer-events-none z-10" />
    
    <img 
      src={image}
      alt={imageAlt}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-contain p-3 group-hover:scale-110 transition-transform duration-500 ease-out"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
  </div>

  <!-- Conteúdo -->
  <div class="p-6 sm:p-8 relative">
    <!-- Linha decorativa no topo -->
    <div class="absolute top-0 left-0 w-0 group-hover:w-full h-0.5 bg-gradient-to-r from-accent to-transparent transition-all duration-500" />
    
    <!-- Categoria -->
    <p class="text-xs font-semibold text-accent uppercase tracking-widest mb-3 transition-all duration-300 group-hover:tracking-wider group-hover:text-accent/70">
      {product.category}
    </p>

    <!-- Nome do Produto -->
    <h3 class="text-lg sm:text-xl font-semibold text-primary-900 mb-3 line-clamp-2 leading-tight transition-colors duration-300 group-hover:text-accent">
      {name}
    </h3>

    <!-- Descrição -->
    <p class="text-sm text-gray-600 mb-5 line-clamp-2 leading-relaxed transition-colors duration-300 group-hover:text-gray-700">
      {description}
    </p>

    <!-- Preço ou CTA -->
    <div class="flex items-center justify-between mb-4">
      <span class="text-sm font-medium text-gray-500 group-hover:text-accent transition-colors duration-300">
        Consultar Preço
      </span>
    </div>

    <!-- CTA -->
    <a 
      href={`/produto/${id}`}
      class="block w-full text-center px-4 sm:px-5 py-3 bg-primary-900 text-white font-semibold text-sm sm:text-base rounded-xl hover:bg-accent active:bg-primary-950 transform hover:scale-110 active:scale-95 transition-all duration-300 ease-out shadow-lg hover:shadow-xl relative overflow-hidden group/btn"
    >
      <!-- Shine effect no botão -->
      <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent transform -translate-x-full group-hover/btn:translate-x-full transition-transform duration-700 pointer-events-none" />
      <span class="relative">Ver Detalhes</span>
    </a>
  </div>
</article>
