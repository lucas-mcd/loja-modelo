---
interface Props {
  text?: string;
  message?: string;
  phone?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
}

const {
  text = 'Consultar no WhatsApp',
  message = 'Olá! Gostaria de saber mais sobre os produtos Cereon.',
  phone = '5585999999999',
  variant = 'primary',
  size = 'md'
} = Astro.props;

const whatsappURL = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;

const baseStyles = 'inline-flex items-center justify-center font-medium rounded-xl transition-all duration-300 ease-in-out gap-2 button-interactive active:scale-95 relative overflow-hidden';
const variants = {
  primary: 'bg-accent text-white hover:bg-opacity-80 hover:shadow-xl hover:-translate-y-1.5 hover:scale-105',
  secondary: 'border-2 border-primary-900 text-primary-900 hover:bg-primary-50 hover:shadow-lg hover:-translate-y-1',
  ghost: 'text-accent hover:bg-accent/10 hover:-translate-y-0.5'
};
const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg'
};
---

<a 
  href={whatsappURL}
  target="_blank"
  rel="noopener noreferrer"
  class={`${baseStyles} ${variants[variant]} ${sizes[size]}`}
>
  <!-- Shine effect overlay -->
  <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent transform -translate-x-full group-hover:translate-x-full transition-transform duration-700 pointer-events-none" />
  
  <!-- WhatsApp Icon -->
  <svg class="w-5 h-5 transition-all duration-300 group-hover:scale-125 group-hover:animate-bounce" fill="currentColor" viewBox="0 0 24 24">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004a9.87 9.87 0 00-4.255.949c-1.168.505-2.233 1.234-3.022 2.78m6.284 5.308c-2.566 1.649-5.39.948-6.788-.256-.64-.56-1.23-1.304-1.668-2.128" />
  </svg>
  <span class="relative z-10">{text}</span>
</a>

