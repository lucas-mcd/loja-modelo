---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Cereon', description = 'Moda de qualidade com estilo' } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} - Cereon</title>
  </head>
  <body class="bg-white antialiased">
    <!-- Header -->
    <header class="sticky top-0 z-50 w-full bg-white/95 backdrop-blur-sm border-b border-gray-100">
      <nav class="container-custom flex items-center justify-between h-14 sm:h-16 md:h-20">
        <!-- Logo -->
        <div class="flex items-center">
          <h1 class="text-xl sm:text-2xl md:text-3xl font-bold text-primary-900">Cereon</h1>
        </div>

        <!-- Navigation Desktop -->
        <div class="hidden md:flex items-center gap-12">
          <a href="/" class="link-underline" data-text="Início">
            Início
          </a>
          <a href="/catalogo" class="link-underline" data-text="Catálogo">
            Catálogo
          </a>
          <a href="/sobre" class="link-underline" data-text="Sobre">
            Sobre
          </a>
          <a href="/contato" class="link-underline" data-text="Contato">
            Contato
          </a>
        </div>

        <!-- CTA Desktop -->
        <div class="hidden md:block">
          <a href="https://wa.me/5585999999999?text=Ol%C3%A1!%20Gostaria%20de%20comprar%20uma%20pe%C3%A7a%20Cereon" target="_blank" rel="noopener noreferrer" class="btn-special">
            <span>Comprar Agora</span>
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <div class="md:hidden">
          <button id="mobileMenuButton" class="p-2 hover:bg-gray-100 rounded-lg transition-all duration-300 hover:scale-110" aria-label="Abrir menu">
            <svg class="w-6 h-6 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </nav>

      <!-- Mobile Menu -->
      <div id="mobileMenu" class="hidden md:hidden fixed left-0 top-20 right-0 bg-white border-b border-gray-100 shadow-lg z-40 animate-slideInDown">
        <div class="container-custom py-4 space-y-2">
          <a href="/" class="block px-4 py-2 text-gray-700 hover:bg-gray-50 hover:text-accent rounded-lg transition-all duration-200">
            Início
          </a>
          <a href="/catalogo" class="block px-4 py-2 text-gray-700 hover:bg-gray-50 hover:text-accent rounded-lg transition-all duration-200">
            Catálogo
          </a>
          <a href="/sobre" class="block px-4 py-2 text-gray-700 hover:bg-gray-50 hover:text-accent rounded-lg transition-all duration-200">
            Sobre
          </a>
          <a href="/contato" class="block px-4 py-2 text-gray-700 hover:bg-gray-50 hover:text-accent rounded-lg transition-all duration-200">
            Contato
          </a>
          <hr class="my-2" />
          <a href="https://wa.me/5585999999999?text=Ol%C3%A1!%20Gostaria%20de%20comprar%20uma%20pe%C3%A7a%20Cereon" target="_blank" rel="noopener noreferrer" class="block px-4 py-2 bg-accent text-white font-semibold hover:bg-accent/90 hover:scale-105 active:scale-95 rounded-lg transition-all duration-200 text-center">
            Comprar Agora
          </a>
        </div>
      </div>
    </header>

    <script>
      const mobileMenuButton = document.getElementById('mobileMenuButton');
      const mobileMenu = document.getElementById('mobileMenu');

      mobileMenuButton?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });

      // Fechar menu ao clicar em um link
      document.querySelectorAll('#mobileMenu a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
        });
      });

      // Fechar menu ao clicar fora
      document.addEventListener('click', (e) => {
        if (!e.target.closest('header')) {
          mobileMenu?.classList.add('hidden');
        }
      });

      // Controle de animação do botão para evitar múltiplas disparos
      const btnSpecial = document.querySelector('.btn-special');
      if (btnSpecial) {
        let isAnimating = false;
        
        // Aumentar zona de detecção do mouse
        btnSpecial.addEventListener('mouseenter', () => {
          if (!isAnimating) {
            isAnimating = true;
            // Adiciona classe que força a animação mesmo se mouse sair
            btnSpecial.classList.add('animating');
            
            // A animação dura 0.95s, depois remove a classe
            setTimeout(() => {
              btnSpecial.classList.remove('animating');
              isAnimating = false;
            }, 950);
          }
        });

        // Também previne hover de sair enquanto está animando
        btnSpecial.addEventListener('mouseleave', () => {
          // Se estiver animando, não faz nada
          // A classe 'animating' mantém a animação visível
        });
      }

      // Animar links de navegação com efeito premium
      function setupNavigationLinks() {
        const links = document.querySelectorAll('.link-underline');
        links.forEach(link => {
          const text = link.textContent.trim();
          link.setAttribute('data-text', text);
          console.log('Link setup:', text, link.getAttribute('data-text'));
        });
      }

      // Executar assim que o script rodar
      setupNavigationLinks();

      // Also setup on DOM content loaded as fallback
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupNavigationLinks);
      }
    </script>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-100 bg-gray-50/50 mt-20">
      <div class="container-custom section-padding">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 sm:gap-8 mb-8 sm:mb-12">
          <!-- Brand -->
          <div>
            <h3 class="text-xl font-bold text-primary-900 mb-4">Cereon</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Moda de qualidade com estilo. Roupas, calçados e acessórios selecionados para você.
            </p>
          </div>

          <!-- Quick Links -->
          <div>
            <h4 class="font-semibold text-gray-900 mb-4">Navegação</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/" class="text-gray-600 hover:text-accent transition-colors">Início</a></li>
              <li><a href="/catalogo" class="text-gray-600 hover:text-accent transition-colors">Catálogo</a></li>
              <li><a href="/sobre" class="text-gray-600 hover:text-accent transition-colors">Sobre</a></li>
            </ul>
          </div>

          <!-- Support -->
          <div>
            <h4 class="font-semibold text-gray-900 mb-4">Suporte</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/contato" class="text-gray-600 hover:text-accent transition-colors">Contato</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="font-semibold text-gray-900 mb-4">Contato</h4>
            <ul class="space-y-2 text-sm text-gray-600">
              <li>
                <a href="https://wa.me/5585999999999" class="hover:text-accent transition-colors">
                  WhatsApp
                </a>
              </li>
              <li>
                <a href="mailto:contato@cereon.com.br" class="hover:text-accent transition-colors">
                  Email
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Divider -->
        <div class="border-t border-gray-200 pt-8">
          <p class="text-center text-sm text-gray-600">
            &copy; 2026 Cereon Digital Systems. Todos os direitos reservados.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
